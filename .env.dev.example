# ============================================================
# Docker dev stack template.
# Copy: cp .env.dev.example .env.dev
# Dev secrets can be simple — this stack is local only.
# ============================================================

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=CHANGE_ME_dev_docker_key
DEBUG=true
USE_DOCKER=true
USE_S3=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=CHANGE_ME_dev_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/music-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false
AWS_S3_URL_PROTOCOL=http:

REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
