# ============================================================
# PRODUCTION environment template.
#
# Setup:
#   cp .env.prod.example .env.prod
#   ./scripts/generate-secrets.sh   (generates strong values)
#   ./scripts/check-env.sh          (validates before deploy)
#
# .env.prod is gitignored — NEVER commit real secrets.
# Rotate secrets immediately if this file is ever leaked.
# ============================================================

DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate: ./scripts/generate-secrets.sh
DJANGO_SECRET_KEY=CHANGE_ME_min_50_chars
DEBUG=false
USE_DOCKER=true
USE_S3=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CSRF_TRUSTED_ORIGINS=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost
# Phase 5: flip to true when HTTPS is set up (Day 40)
DJANGO_SECURE_SSL=false

POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# MinIO root credentials — ACCESS_KEY_ID is the username,
# SECRET_ACCESS_KEY is the password. Min 8 chars each.
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://minio:9000
# Phase 5: change to your-domain.com/music-media
AWS_S3_CUSTOM_DOMAIN=localhost/music-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
