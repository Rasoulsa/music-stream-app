# ============================================================
# PRODUCTION environment template.
#
# Setup:
#   cp .env.prod.example .env.prod
#   nano .env.prod   ← fill in YOUR_VPS_IP and all CHANGE_ME values
#
# .env.prod is gitignored — NEVER commit real secrets.
# Rotate secrets immediately if ever leaked.
#
# Day 39: fill YOUR_VPS_IP throughout this file.
# Day 40: add music domain to ALLOWED_HOSTS, CSRF, CORS, S3_CUSTOM_DOMAIN.
#         flip DJANGO_SECURE_SSL=true and NGINX_HTTP_BIND=127.0.0.1:8444.
# ============================================================

# ── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production

# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be 50+ characters (required by SimpleJWT HMAC key length).
DJANGO_SECRET_KEY=CHANGE_ME_min_50_chars_use_generate_secrets_script

DEBUG=false
USE_DOCKER=true
USE_S3=true

# I:  VPS IP only.
# II: add your music domain, e.g.: YOUR_VPS_IP,music.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,YOUR_VPS_IP

# I:  http://YOUR_VPS_IP only.
# II: add https://music.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://YOUR_VPS_IP
CORS_ALLOWED_ORIGINS=http://YOUR_VPS_IP

# Flip to true on II AFTER HTTPS is confirmed working.
# Do NOT enable before HTTPS — it will break the HTTP-only I deploy.
DJANGO_SECURE_SSL=false

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── MinIO / S3 ───────────────────────────────────────────────
# These vars serve double duty:
#   - Django uses them to talk to MinIO via S3-compatible API.
#   - docker-compose.yml maps them to MINIO_ROOT_USER/PASSWORD
#     for the MinIO container itself.
# So AWS_ACCESS_KEY_ID IS the MinIO admin username.
# Minimum 8 characters for both.
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key_min8chars
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key_min8chars
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://minio:9000

# Day 39: YOUR_VPS_IP/music-media  (plain HTTP, VPS IP)
# Day 40: music.yourdomain.com/music-media  (HTTPS, your domain)
AWS_S3_CUSTOM_DOMAIN=YOUR_VPS_IP/music-media

AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false
AWS_S3_URL_PROTOCOL=http:

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ── Nginx host binding ───────────────────────────────────────
# I:  App Nginx binds all interfaces on port 80.
# II: set to 127.0.0.1:8444 — HAProxy will then front :443.
NGINX_HTTP_BIND=0.0.0.0:80
