# ============================================================
# PRODUCTION environment template
# ============================================================
#
# Setup:
#   cp .env.prod.example .env.prod
#   ./scripts/generate-secrets.sh
#   nano .env.prod
#
# Recommended secret generation:
#   ./scripts/generate-secrets.sh
#
# The script prints strong values for:
#   - DJANGO_SECRET_KEY
#   - POSTGRES_PASSWORD
#   - AWS_ACCESS_KEY_ID
#   - AWS_SECRET_ACCESS_KEY
#   - GRAFANA_ADMIN_PASSWORD
#
# Copy the generated KEY=VALUE lines into .env.prod and replace
# the CHANGE_ME_* placeholders.
#
# VPS HTTPS preparation:
#   make vps-prepare-https
#
# Initial Let's Encrypt certificate:
#   make vps-issue-cert
#
# Replace manually:
#   - YOUR_VPS_IP
#   - music.example.com
#   - CHANGE_ME_* values
#   - you@example.com
#
# SECURITY:
#   .env.prod is gitignored and must NEVER be committed.
#   If real secrets are leaked, rotate them immediately.
#
# Deployment phases:
#
#   Phase I — HTTP only, VPS IP access
#     - Use http://YOUR_VPS_IP
#     - Keep DJANGO_SECURE_SSL=false
#     - Keep NGINX_HTTP_BIND=0.0.0.0:80
#     - NGINX_HTTPS_BIND can stay defined but is only used by the VPS HTTPS overlay
#
#   Phase II — HTTPS with domain + HAProxy SNI splitting
#     - Point DNS A record to YOUR_VPS_IP
#     - Set APP_DOMAIN=music.example.com
#     - Add domain to DJANGO_ALLOWED_HOSTS
#     - Add https://music.example.com to CSRF_TRUSTED_ORIGINS
#     - Set AWS_S3_CUSTOM_DOMAIN=music.example.com/music-media
#     - Keep NGINX_HTTP_BIND=0.0.0.0:80
#       Used for Let's Encrypt HTTP-01 challenge + HTTP -> HTTPS redirect
#     - Set NGINX_HTTPS_BIND=127.0.0.1:8443
#       HAProxy forwards HTTPS SNI traffic to this local port
#     - Set DJANGO_SECURE_SSL=true only AFTER HTTPS is confirmed working
#
# ============================================================

# ============================================================
# Django
# ============================================================

DJANGO_SETTINGS_MODULE=config.settings.production

# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Must be strong and unique per environment.
# Recommended length: 50+ characters.
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64

DEBUG=false
USE_DOCKER=true

# Enable S3-compatible object storage.
# In this project, production uses MinIO/S3-compatible storage.
USE_S3=true

# No schemes here. Comma-separated hostnames/IPs only.
#
# Phase I example:
#   DJANGO_ALLOWED_HOSTS=YOUR_VPS_IP,localhost,127.0.0.1,backend,nginx
#
# Phase II example:
#   DJANGO_ALLOWED_HOSTS=music.example.com,YOUR_VPS_IP,localhost,127.0.0.1,backend,nginx
DJANGO_ALLOWED_HOSTS=music.example.com,YOUR_VPS_IP,localhost,127.0.0.1,backend,nginx

# CSRF origins require scheme.
#
# Phase I:
#   CSRF_TRUSTED_ORIGINS=http://YOUR_VPS_IP
#
# Phase II:
#   CSRF_TRUSTED_ORIGINS=https://music.example.com
#
# During transition, you may temporarily include both.
CSRF_TRUSTED_ORIGINS=http://YOUR_VPS_IP,https://music.example.com

# CORS origins also require scheme.
#
# If frontend and backend are served from the same domain through nginx,
# CORS is less important, but keeping the public origin explicit is fine.
CORS_ALLOWED_ORIGINS=http://YOUR_VPS_IP,https://music.example.com

# Keep false for initial HTTP/VPS deployment.
# Change to true only after:
#   - certificate exists
#   - HAProxy SNI routing works
#   - https://APP_DOMAIN loads correctly
DJANGO_SECURE_SSL=false


# ============================================================
# Domain / HTTPS / Let's Encrypt
# ============================================================

# Public domain for the app.
#
# Used by:
#   - nginx/app-ssl.conf.template for certificate paths
#   - HAProxy SNI routing
#   - Django allowed hosts/origins
#
# Example:
#   APP_DOMAIN=music.example.com
APP_DOMAIN=music.example.com

# Email used by Let's Encrypt for registration and expiry notices.
ACME_EMAIL=you@example.com


# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_DB=musicdb
POSTGRES_USER=musicuser

# Generate a strong password.
# Example:
#   openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Inside Docker Compose, the hostname is the service name.
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ============================================================
# MinIO / S3-compatible storage
# ============================================================

# These variables are used by Django to access object storage.
# They are also mapped to MinIO root credentials in docker-compose.yml.
#
# The app uses django-storages S3 backend. This works with BOTH MinIO and
# real AWS S3 — only the values below change.
#
# Minimum 8 characters for MinIO access/secret keys.
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key_min_8_chars
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key_min_8_chars

AWS_STORAGE_BUCKET_NAME=music-media

# Internal Docker network endpoint.
# Django talks to MinIO through this private URL.
#
# Keep this as http://minio:9000 unless you explicitly configure TLS
# inside the Docker network.
AWS_S3_ENDPOINT_URL=http://minio:9000

# Public object/media URL domain.
#
# Phase I, HTTP/IP:
#   AWS_S3_CUSTOM_DOMAIN=YOUR_VPS_IP/music-media
#
# Phase II, HTTPS/domain:
#   AWS_S3_CUSTOM_DOMAIN=music.example.com/music-media
AWS_S3_CUSTOM_DOMAIN=music.example.com/music-media

AWS_S3_REGION_NAME=us-east-1

# Public URL protocol generated for uploaded/media files.
#
# Phase I:
#   AWS_S3_URL_PROTOCOL=http:
#
# Phase II:
#   AWS_S3_URL_PROTOCOL=https:
#
# Keep as http: until HTTPS is confirmed.
AWS_S3_URL_PROTOCOL=http:

# Important:
# This controls Django/boto's connection to the S3 endpoint.
# Since AWS_S3_ENDPOINT_URL=http://minio:9000 is internal HTTP,
# keep this false even after public HTTPS is enabled.
#
# Only set true if AWS_S3_ENDPOINT_URL itself becomes HTTPS.
AWS_S3_USE_SSL=false
#
# --- Real AWS S3 (production) ---
# Leave AWS_S3_ENDPOINT_URL UNSET (or empty) to target AWS S3 directly.
# AWS_ACCESS_KEY_ID=<iam-access-key>
# AWS_SECRET_ACCESS_KEY=<iam-secret-key>
# AWS_STORAGE_BUCKET_NAME=music-media-prod
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=eu-central-1

# ============================================================
# Redis / Celery
# ============================================================

REDIS_URL=redis://redis:6379/1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Must be false in real production.
CELERY_TASK_ALWAYS_EAGER=false


# ============================================================
# Nginx host bindings
# ============================================================

# HTTP binding.
#
# Phase I:
#   App nginx listens publicly on :80.
#
# Phase II:
#   App nginx still listens publicly on :80 for:
#     - Let's Encrypt HTTP-01 challenge
#     - HTTP -> HTTPS redirect
NGINX_HTTP_BIND=0.0.0.0:80

# HTTPS binding for the app nginx container.
#
# Do NOT bind public :443 here.
# Public :443 belongs to HAProxy.
#
# HAProxy listens on :443 and forwards SNI-matched traffic to:
#   127.0.0.1:8443
NGINX_HTTPS_BIND=127.0.0.1:8443


# ============================================================
# Monitoring (Grafana)
# ============================================================
# Monitoring UI ports.
#
# Bound to 127.0.0.1 only in docker-compose.monitoring.yml.
# This avoids exposing Prometheus/Grafana publicly.
#
# Grafana uses 3001 on the host so it does not conflict with
# the frontend dev server on localhost:3000.
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me


# ============================================================
# Backups
# ============================================================
# Host directory for backup artifacts (default: <project>/backups)
# BACKUP_ROOT=
# Retention
KEEP_DAILY=7
KEEP_WEEKLY=4
# Optional off-site (S3 / S3-compatible)
BACKUP_REMOTE_UPLOAD=false
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=

# Optional: manual rsync offsite to a secondary host
# Run with: make backup-rsync
# BACKUP_RSYNC_HOST=deploy@backup.example.com
# BACKUP_RSYNC_PATH=/opt/backups/music-stream-app
# BACKUP_RSYNC_KEY=/home/deploy/.ssh/backup_key
