# =========================================
# Python / Django
# =========================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
.python-version

# Python build outputs
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Django local database / media / static
*.sqlite3
db.sqlite3
backend/media/
backend/staticfiles/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.ruff_cache/
.mypy_cache/

# =========================================
# Environment variables / secrets
# =========================================
# Real env files are NEVER committed.
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Exception: example/template files ARE committed.
# These contain only CHANGE_ME placeholders, never real secrets.
!.env.example
!.env.*.example
!frontend/.env.example
!frontend/.env.*.example

# TLS/SSL keys — never commit
*.pem
*.key
*.crt

# =========================================
# Node / React
# =========================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
.vite/

# =========================================
# Logs
# =========================================
*.log
logs/

# =========================================
# Docker / local runtime
# =========================================
docker-data/
*.pid

# =========================================
# OS / Editor
# =========================================
.DS_Store
Thumbs.db
.idea/
.vscode/

# =========================================
# Temporary files
# =========================================
tmp/
temp/
.cache/
