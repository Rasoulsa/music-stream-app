# =============================================================
# Docker environment template
# Copy this to .env.docker and fill in real values:
#   cp backend/.env.docker.example backend/.env.docker
# =============================================================

# -------------------------------------------------------------
# Django
# -------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Set to False ONLY for local HTTP testing. True in real production.
DJANGO_SECURE_SSL=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=music
POSTGRES_USER=music
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -------------------------------------------------------------
# Redis
# Docker service hostname is "redis".
# DB layout: /0 → Celery broker (Day 16)  |  /1 → Django cache (Day 15)
# -------------------------------------------------------------
REDIS_URL=redis://redis:6379/1

# -------------------------------------------------------------
# Object Storage (MinIO in Docker / S3 in production)
# In Docker we use MinIO, so USE_S3=true.
# -------------------------------------------------------------
USE_S3=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/music-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false


# ── Celery ──
# Docker/prod: point at Redis, EAGER=false (real async worker)
# Local dev:   leave broker default, EAGER=true (runs in-process, no worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true
