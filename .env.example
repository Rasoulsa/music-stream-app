# ============================================================
# Local development template — NO Docker.
# Copy: cp .env.example .env
# Docs: docs/day-33-secrets.md
# ============================================================

DJANGO_SETTINGS_MODULE=config.settings.dev
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_local_dev_key
DEBUG=true
USE_DOCKER=false
USE_S3=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=CHANGE_ME_local_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/music-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false
AWS_S3_URL_PROTOCOL=http:

REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true

VITE_API_BASE_URL=http://localhost:8000/api/v1
