# ── Django ──
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY="e@h=)8_o%@p(df*-qkw!(d^_2w4%cu_(dk&25-3mfj5c9iv4wf"
DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CSRF_TRUSTED_ORIGINS=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# HTTP for local prod testing; flip to true with real HTTPS (Phase 5)
DJANGO_SECURE_SSL=false

# ── Database (PostgreSQL) ──
POSTGRES_DB=music
POSTGRES_USER=music
POSTGRES_PASSWORD=musicuser123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Object Storage (MinIO; real S3 in cloud later) ──
USE_S3=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=music-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/music-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

# ── Redis ──
REDIS_URL=redis://redis:6379/1

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
