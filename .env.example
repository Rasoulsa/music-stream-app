# =========================================
# Django
# =========================================
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =========================================
# PostgreSQL
# =========================================
POSTGRES_DB=musicdb
POSTGRES_USER=musicuser
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =========================================
# Redis
# Docker: redis://redis:6379/1
# Local:  redis://localhost:6379/1
# Empty:  in-memory cache (local dev, no Redis needed)
# =========================================
REDIS_URL=

# =========================================
# MinIO / S3-compatible storage
# Local development will use MinIO.
# Later, cloud deployment can use AWS S3.
# =========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=music-media
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=False

# =========================================
# Frontend
# =========================================
VITE_API_BASE_URL=http://localhost:8000/api

# =========================================
# Environment mode
# Controls which database Django uses in dev.
# false → SQLite  (local development, no Docker needed)
# true  → PostgreSQL  (Docker development, matches production)
# =========================================
USE_DOCKER=false

# =========================================
# Storage mode
# false → local disk | true → MinIO/S3
# =========================================
USE_S3=false
